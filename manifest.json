{
    "manifest_version": 2,
    "name": "SearchLater",
    "version": "0.1",
    "description": "Firefox extension for all those times your brain got curious about something totally unrelated to the task at hand. Save them here so you can look at them later!",
    
    "browser_specific_settings": {
        "gecko": {
            "id": "SearchLater@amigurumishaders.com", 
            "strict_min_version": "100.0" 
        }
    },
    
    "icons": {
        "48": "icons\\searchlater48.png"
    },
    "browser_action": {
        "default_icon": {
            "32": "icons\\searchlater.png"
        },
        "default_title": "SearchLater",
        "default_popup": "popup/search_later.html"
    },
    "permissions":[
        "storage"
    ]
}